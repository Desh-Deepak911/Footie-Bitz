# OpenAI API key (required for script generation and voiceover)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_key_here

# Optional: API-Football for Football Research Mode (server-only — never expose to client)
# Get a key at: https://www.api-football.com/
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_KEY=

# Optional: override default API-Football season for league topscorers (e.g. 2024)
# API_FOOTBALL_SEASON=2024
# OPENAI_SCRIPT_MODEL=gpt-4.1-mini
